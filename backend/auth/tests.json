{
  "tests": [
    {
      "name": "Register - short username",
      "method": "POST",
      "path": "/?action=register",
      "body": {"username": "ab", "password": "123456"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Имя пользователя минимум 3 символа"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login - wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": {"username": "nobody", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверное имя пользователя или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me - no token",
      "method": "POST",
      "path": "/?action=me",
      "body": {},
      "expectedStatus": 401,
      "expectedBody": {"error": "Нет токена"},
      "bodyMatcher": "partial"
    }
  ]
}